{
  "name": "animation-engine",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "parcel",
    "build": "parcel build"
  },
  "targets": {
    "lib": {
      "source": "src/engine/index.ts",
      "distDir": "dist/",
      "context": "browser",
      "outputFormat": "esmodule",
      "isLibrary": true,
      "optimize": true
    },
    "app": {
      "source": "src/index.html",
      "distDir": "dist/"
    }
  },
  "devDependencies": {
    "parcel": "^2.16.0",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.0.1"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "codemirror": "^6.0.2"
  }
}
